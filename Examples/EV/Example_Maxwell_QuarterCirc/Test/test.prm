# Listing of Parameters
# ---------------------

subsection newtonsolver_eigenvalueproblem parameters
 # maximal number of linesearch steps
 set line_maxiter         = 8

  # reduction rate for the linesearch damping parameter
 set linesearch_rho       = 0.9

  # global tolerance for the newton iteration
 set nonlinear_global_tol = 1.e-12

  # maximal number of newton iterations
 set nonlinear_maxiter    = 100

  # minimal  newton reduction, if actual reduction is less, matrix is rebuild
 set nonlinear_rho        = 0.1

  # relative tolerance for the newton iteration
 set nonlinear_tol        = 1.e-10
end

subsection eigenvalue_solver parameters
 set tol = 1.e-8
 set target_eigenvalue = 0.94 #1.2
 #set maxiter = 1000
end

subsection localfunctional parameters
	set target_eigenvalue = 1.2
	set epsilon = 0.001
	set alpha = 0.01
	set beta = 0.001
end 

subsection eigenvaluereducedproblem parameters
	#TODO
	set target_eigenvalue = 1.2
	set number_of_eigenvalues = 1
	set eigenvalue_index = 0 #first eigenvalue: index = 0
end

subsection output parameters
  # File format for the output of control variables
  set control_file_format     = .vtk

  # Log Debug Information
  set debug                   = false

  # Correlation of the output and machine precision
  set eps_machine_set_by_user = 1.0e-8

  # File format for the output of solution variables
  set file_format             = .vtk

  # Iteration Counters that should not reflect in the outputname, seperated by
  # `;`
  set ignore_iterations       = PDENewton;Cg

  # Name of the logfile
  set logfile                 = dope.log

  # Do not write files whose name contains a substring given here by a list of
  # `;` separated words
 # set never_write_list        = Adjoint;Residual;Hessian;Tangent;Adjoint;State;Update;Intermediate;Gradient

  # Sets the precision of the output numbers
  set number_precision        = 5

  # Defines what strings should be printed, the higher the number the more
  # output
  set printlevel              = 4 #20 #

  # Directory where the output goes to
  set results_dir             = ./
end
 

subsection reducedDampedBFGSalgorithm parameters
 set nonlinear_maxiter = 100
 set nonlinear_tol = 1.e-6
 set nonlinear_global_tol = 1.e-6
 set line_maxiter = 300 
 set linesearch_gamma = 0.1
# set memory = 40
 set init_inverse_scale = 0.01 # identisch zu alpha und neq 0
 set compute_functionals_in_every_step = false 
end

